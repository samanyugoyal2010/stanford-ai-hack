# Secrets — NEVER bake these. Users paste their own key at runtime (encrypted in
# the runtime SQLite DB, never committed).
.env
.env.*

# Host build artifacts — must NOT enter the image (macOS-native binaries, stale builds).
**/node_modules
**/.next
**/.turbo
**/.cache
**/.transformers-cache
.git
*.log

# Runtime-generated data (sqlite DB, auto enc-key, scratch) — regenerated on boot.
data
