{
  "name": "openlive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "bash scripts/free-ports.sh",
    "dev": "concurrently -k --kill-others -n web,agent -c cyan,magenta \"pnpm --filter @openlive/web dev\" \"pnpm --filter @openlive/agent dev\"",
    "stop": "bash scripts/free-ports.sh",
    "build": "pnpm -r --filter @openlive/web build",
    "db:reset": "pnpm --filter @openlive/db reset",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.3"
  }
}
