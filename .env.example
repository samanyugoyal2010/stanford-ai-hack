# OpenLive — all provider API keys are entered in the UI (Settings ⚙), not here.
# Everything below is OPTIONAL with sensible local defaults for `pnpm dev`.

# Where the web app reaches the agent service.
AGENT_SERVICE_URL=http://localhost:8787
# Public origin of the web app.
WEB_PUBLIC_URL=http://localhost:3000
# Ports
WEB_PORT=3000
AGENT_PORT=8787
# The browser's direct live WebSocket in dev (the web dev script sets this).
NEXT_PUBLIC_LIVE_WS_URL=ws://localhost:8787
# 32-byte hex key encrypting provider API keys at rest. Auto-generated to
# data/.enc-key on first run if left blank. Set explicitly for stable storage.
OPENLIVE_ENC_KEY=
# Shared secret the web proxy sends the agent (x-openlive-secret). Blank for
# local dev (agent listens on localhost only). Set for any non-localhost deploy.
OPENLIVE_AGENT_SECRET=
# Where the SQLite DB + cached model catalog live. Defaults to ./data.
OPENLIVE_DATA_DIR=
